<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Dracula Theme - Purple/pink accents, Transylvanian vibes -->
    <Color x:Key="BackgroundPrimaryColor">#282A36</Color>
    <Color x:Key="BackgroundSecondaryColor">#21222C</Color>
    <Color x:Key="BackgroundTertiaryColor">#44475A</Color>
    <Color x:Key="AccentColor">#BD93F9</Color>
    <Color x:Key="AccentHoverColor">#FF79C6</Color>
    <Color x:Key="TextPrimaryColor">#F8F8F2</Color>
    <Color x:Key="TextSecondaryColor">#6272A4</Color>
    <Color x:Key="BorderColor">#44475A</Color>
    <Color x:Key="SelectionBgColor">#44475A</Color>
    <Color x:Key="SelectionBorderColor">#BD93F9</Color>
    <Color x:Key="HoverBgColor">#343746</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundTertiary" Color="{StaticResource BackgroundTertiaryColor}"/>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SelectionBg" Color="{StaticResource SelectionBgColor}"/>
    <SolidColorBrush x:Key="SelectionBorder" Color="{StaticResource SelectionBorderColor}"/>
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverBgColor}"/>
    
    <!-- Button Style -->
    <Style x:Key="ToolButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Accent}"/>
                            <Setter Property="Foreground" Value="#282A36"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            <Setter Property="Foreground" Value="#282A36"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Window Style -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
    </Style>
    
</ResourceDictionary>
