<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Solarized Light - warm parchment + cool accents -->
    <Color x:Key="BackgroundPrimaryColor">#FDF6E3</Color>
    <Color x:Key="BackgroundSecondaryColor">#EEE8D5</Color>
    <Color x:Key="BackgroundTertiaryColor">#E4DCCB</Color>
    <Color x:Key="AccentColor">#268BD2</Color>
    <Color x:Key="AccentHoverColor">#2AA198</Color>
    <Color x:Key="TextPrimaryColor">#073642</Color>
    <Color x:Key="TextSecondaryColor">#586E75</Color>
    <Color x:Key="BorderColor">#93A1A1</Color>
    <Color x:Key="SelectionBgColor">#DCD4C0</Color>
    <Color x:Key="SelectionBorderColor">#268BD2</Color>
    <Color x:Key="HoverBgColor">#E8E0CC</Color>

    <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundTertiary" Color="{StaticResource BackgroundTertiaryColor}"/>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SelectionBg" Color="{StaticResource SelectionBgColor}"/>
    <SolidColorBrush x:Key="SelectionBorder" Color="{StaticResource SelectionBorderColor}"/>
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverBgColor}"/>

</ResourceDictionary>
