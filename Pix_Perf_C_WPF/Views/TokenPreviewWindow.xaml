<Window x:Class="PixelPerfect.Views.TokenPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Token Preview" Height="800" Width="1000"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BackgroundPrimary}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Viewport3D x:Name="Viewport" Grid.Column="0" 
                    MouseDown="Viewport_MouseDown" MouseMove="Viewport_MouseMove" MouseUp="Viewport_MouseUp" MouseWheel="Viewport_MouseWheel">
            <Viewport3D.Camera>
                <PerspectiveCamera x:Name="MainCamera" Position="0, 0, 80" LookDirection="0, 0, -1" UpDirection="0, 1, 0" FieldOfView="45"/>
            </Viewport3D.Camera>
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup x:Name="MainModelGroup">
                        <AmbientLight Color="#888888"/>
                        <DirectionalLight Color="#FFFFFF" Direction="-1,-1,-1" />
                        <!-- Empty container to hold our voxel model -->
                        <Model3DGroup x:Name="VoxelModelGroup">
                            <Model3DGroup.Transform>
                                <Transform3DGroup>
                                    <RotateTransform3D>
                                        <RotateTransform3D.Rotation>
                                            <AxisAngleRotation3D x:Name="ModelRotationX" Axis="1,0,0" Angle="0"/>
                                        </RotateTransform3D.Rotation>
                                    </RotateTransform3D>
                                    <RotateTransform3D>
                                        <RotateTransform3D.Rotation>
                                            <AxisAngleRotation3D x:Name="ModelRotationY" Axis="0,1,0" Angle="0"/>
                                        </RotateTransform3D.Rotation>
                                    </RotateTransform3D>
                                </Transform3DGroup>
                            </Model3DGroup.Transform>
                        </Model3DGroup>
                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>
        </Viewport3D>

        <Border Grid.Column="1" Background="{DynamicResource BackgroundSecondary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Padding="15">
            <StackPanel>
                <TextBlock Text="3D Tokenizer" FontSize="18" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <TextBlock Text="Token Thickness:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                <Slider x:Name="ThicknessSlider" Minimum="0.1" Maximum="10" Value="1" ValueChanged="Controls_ValueChanged" Margin="0,0,0,20" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                
                <CheckBox x:Name="AutoSpinCheck" Content="Auto Spin" Foreground="{DynamicResource TextPrimary}" IsChecked="True" Checked="AutoSpin_Checked" Unchecked="AutoSpin_Unchecked" Margin="0,0,0,15"/>

                <Button Content="Reset View" Style="{DynamicResource ToolButton}" Click="ResetView_Click" Padding="10" Margin="0,0,0,10" BorderThickness="1"/>
                
                <!-- Close Button -->
                <Button Content="Close" Click="Close_Click" Padding="10" Margin="0,50,0,0" Background="#e06c75" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
