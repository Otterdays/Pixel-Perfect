<Window x:Class="PixelPerfect.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PixelPerfect.ViewModels"
        xmlns:converters="clr-namespace:PixelPerfect.Converters"
        mc:Ignorable="d"
        Title="Pixel Perfect" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimary}">
    
    <Window.Resources>
        <converters:PixelColorToBrushConverter x:Key="PixelColorToBrushConverter"/>
        <converters:NegateConverter x:Key="NegateConverter"/>
        <converters:InverseZoomConverter x:Key="InverseZoomConverter"/>
        <converters:ColorSwatchToolTipConverter x:Key="ColorSwatchToolTipConverter"/>
        
        <!-- Styled tooltip: title, short desc, nitty gritty -->
        <DataTemplate x:Key="ColorSwatchToolTipTemplate" DataType="converters:ColorSwatchToolTipContent">
            <StackPanel MaxWidth="260">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ShortDescription}" FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}" Opacity="0.95" Margin="0,0,0,6"/>
                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,4" Opacity="0.6"/>
                <TextBlock Text="{Binding Details}" FontSize="10" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondary}" Opacity="0.85"/>
            </StackPanel>
        </DataTemplate>
        
        <Style x:Key="StyledToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
        
        <!-- Tool tooltips: title, short desc, nitty gritty -->
        <converters:ColorSwatchToolTipContent x:Key="BrushToolTipContent"
            Title="Brush (B)" ShortDescription="Draw pixels. Click or drag on the canvas."
            Details="Variable size (1–32px). Uses current color."/>
        <converters:ColorSwatchToolTipContent x:Key="EraserToolTipContent"
            Title="Eraser (E)" ShortDescription="Remove pixels. Makes them transparent."
            Details="Variable size. Same hotkey as brush size."/>
        <converters:ColorSwatchToolTipContent x:Key="FillToolTipContent"
            Title="Fill (F)" ShortDescription="Flood-fill an area with the current color."
            Details="Click inside a closed region. Replaces matching connected pixels."/>
        <converters:ColorSwatchToolTipContent x:Key="EyedropperToolTipContent"
            Title="Eyedropper (I)" ShortDescription="Pick a color from the canvas."
            Details="Left-click: pick. Right-click: pick composite (all layers)."/>
        <converters:ColorSwatchToolTipContent x:Key="LineToolTipContent"
            Title="Line (L)" ShortDescription="Draw straight lines."
            Details="Drag from start to end. Live preview."/>
        <converters:ColorSwatchToolTipContent x:Key="RectangleToolTipContent"
            Title="Rectangle (R)" ShortDescription="Draw rectangles. Outline or filled."
            Details="Drag to set size. Toggle fill in options."/>
        <converters:ColorSwatchToolTipContent x:Key="CircleToolTipContent"
            Title="Circle (C)" ShortDescription="Draw circles/ellipses."
            Details="Drag for radius. Outline or filled."/>
        <converters:ColorSwatchToolTipContent x:Key="PanToolTipContent"
            Title="Pan (P)" ShortDescription="Move the view without drawing."
            Details="Drag canvas. Also: middle mouse or Space+drag."/>
        <converters:ColorSwatchToolTipContent x:Key="SelectionToolTipContent"
            Title="Selection (S)" ShortDescription="Select a rectangle to copy, cut, or move."
            Details="Drag to select. Then Copy/Cut/Paste/Delete."/>
        <converters:ColorSwatchToolTipContent x:Key="MoveToolTipContent"
            Title="Move (M)" ShortDescription="Move the current selection."
            Details="Drag selection. Non-destructive; keeps background."/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="B" Command="{Binding SelectBrushCommand}"/>
        <KeyBinding Key="E" Command="{Binding SelectEraserCommand}"/>
        <KeyBinding Key="F" Command="{Binding SelectFillCommand}"/>
        <KeyBinding Key="I" Command="{Binding SelectEyedropperCommand}"/>
        <KeyBinding Key="L" Command="{Binding SelectLineCommand}"/>
        <KeyBinding Key="R" Command="{Binding SelectRectangleCommand}"/>
        <KeyBinding Key="C" Command="{Binding SelectCircleCommand}"/>
        <KeyBinding Key="G" Command="{Binding ToggleGridCommand}"/>
        <KeyBinding Key="P" Command="{Binding SelectPanCommand}"/>
        <KeyBinding Key="S" Command="{Binding SelectSelectionCommand}"/>
        <KeyBinding Key="M" Command="{Binding SelectMoveCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewCanvasCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="C" Command="{Binding CopyCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="X" Command="{Binding CutCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="V" Command="{Binding PasteCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="Back" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding EscapeCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleFullscreenCommand}"/>
        <KeyBinding Key="X" Command="{Binding SwapColorsCommand}"/>
        <KeyBinding Key="OemOpenBrackets" Command="{Binding BrushSizeDownCommand}"/>
        <KeyBinding Key="OemCloseBrackets" Command="{Binding BrushSizeUpCommand}"/>
        <KeyBinding Modifiers="Ctrl+Shift" Key="E" Command="{Binding QuickExportCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Toolbar -->
        <Grid Grid.Row="0" Background="{DynamicResource BackgroundSecondary}" Height="40">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <Button Content="New" Style="{DynamicResource ToolButton}" Command="{Binding NewCanvasCommand}" Margin="0,0,4,0"/>
                <Button Content="Open" Style="{DynamicResource ToolButton}" Margin="0,0,4,0"/>
                <Button Content="Save" Style="{DynamicResource ToolButton}" Margin="0,0,4,0" Command="{Binding SaveCommand}" ToolTip="Save to PNG (Ctrl+S)"/>
                <Button Content="↶" Style="{DynamicResource ToolButton}" Command="{Binding UndoCommand}" Margin="0,0,2,0" Width="28" ToolTip="Undo (Ctrl+Z)"/>
                <Button Content="↷" Style="{DynamicResource ToolButton}" Command="{Binding RedoCommand}" Margin="0,0,4,0" Width="28" ToolTip="Redo (Ctrl+Y)"/>
                <TextBlock Text="Export:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding ExportScaleOptions}" SelectedItem="{Binding ExportScale, Mode=TwoWay}"
                          Width="50" VerticalAlignment="Center" ToolTip="PNG export scale (1×–8×)"/>
                
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="0,4,16,4"/>

                <ToggleButton Content="◧" Style="{DynamicResource ToolToggleButton}" FontSize="16"
                              IsChecked="True" Checked="LeftPanelToggle_Checked" Unchecked="LeftPanelToggle_Unchecked"
                              ToolTip="Toggle Tools Panel" Margin="0,0,4,0"/>
                              
                <ToggleButton Content="◨" Style="{DynamicResource ToolToggleButton}" FontSize="16"
                              IsChecked="True" Checked="RightPanelToggle_Checked" Unchecked="RightPanelToggle_Unchecked"
                              ToolTip="Toggle Layers Panel" Margin="0,0,16,0"/>

                <ToggleButton Content="Grid" Style="{DynamicResource ToolToggleButton}"
                              IsChecked="{Binding ShowGrid, Mode=TwoWay}"
                              ToolTip="Toggle grid overlay (G)" Margin="0,0,16,0"/>
                
                <TextBlock Text="Zoom:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ZoomLevels}" 
                          SelectedItem="{Binding Zoom}" 
                          Width="60" VerticalAlignment="Center"/>
                <Button Content="Fit" Style="{DynamicResource ToolButton}" Command="{Binding FitToViewCommand}" Margin="4,0,2,0" Padding="6,2" ToolTip="Fit canvas to view"/>
                <Button Content="100%" Style="{DynamicResource ToolButton}" Command="{Binding Zoom100Command}" Margin="0,0,16,0" Padding="6,2" ToolTip="Zoom to 100%"/>
                
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="0,4,16,4"/>
                <TextBlock Text="Theme:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ThemeNames}" 
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" 
                          Width="100" VerticalAlignment="Center" ToolTip="Switch UI theme"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" x:Name="LeftPanelColumn" MinWidth="170" MaxWidth="400"/>
                <ColumnDefinition Width="4" x:Name="LeftSplitterColumn"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4" x:Name="RightSplitterColumn"/>
                <ColumnDefinition Width="200" x:Name="RightPanelColumn" MinWidth="170" MaxWidth="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Tools & Color -->
            <Grid Grid.Column="0" x:Name="LeftPanel" Background="{DynamicResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <!-- Tools Section -->
                    <TextBlock Text="Tools" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Size:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="32" Value="{Binding BrushSize}" VerticalAlignment="Center" ToolTip="Brush/Eraser size (px)"/>
                    </Grid>
                    <UniformGrid Columns="4" Margin="0,0,0,16">
                        <Button Content="✏️" Style="{DynamicResource ToolButton}" Command="{Binding SelectBrushCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource BrushToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="🧹" Style="{DynamicResource ToolButton}" Command="{Binding SelectEraserCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource EraserToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="🪣" Style="{DynamicResource ToolButton}" Command="{Binding SelectFillCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource FillToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="💧" Style="{DynamicResource ToolButton}" Command="{Binding SelectEyedropperCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource EyedropperToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="📏" Style="{DynamicResource ToolButton}" Command="{Binding SelectLineCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource LineToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="⬛" Style="{DynamicResource ToolButton}" Command="{Binding SelectRectangleCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource RectangleToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="⚪" Style="{DynamicResource ToolButton}" Command="{Binding SelectCircleCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource CircleToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="✋" Style="{DynamicResource ToolButton}" Command="{Binding SelectPanCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource PanToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="⬚" Style="{DynamicResource ToolButton}" Command="{Binding SelectSelectionCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource SelectionToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                        <Button Content="✥" Style="{DynamicResource ToolButton}" Command="{Binding SelectMoveCommand}" Width="36" Height="36" Margin="2">
                            <Button.ToolTip><ToolTip Style="{StaticResource StyledToolTip}" Content="{StaticResource MoveToolTipContent}" ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/></Button.ToolTip>
                        </Button>
                    </UniformGrid>
                    
                    <!-- Color Section -->
                    <TextBlock Text="Color" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="4" Margin="0,0,8,0"
                                Background="{Binding CurrentColor, Converter={StaticResource PixelColorToBrushConverter}}"
                                ToolTip="Primary color"/>
                        <Border Grid.Column="1" Width="48" Height="48" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="4"
                                Background="{Binding SecondaryColor, Converter={StaticResource PixelColorToBrushConverter}}" Cursor="Hand"
                                ToolTip="Secondary (X to swap)">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SwapColorsCommand}"/>
                            </Border.InputBindings>
                        </Border>
                    </Grid>
                    <TextBlock Text="Recent" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding RecentColors}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="20" Height="20" Margin="1" Cursor="Hand"
                                        Background="{Binding Converter={StaticResource PixelColorToBrushConverter}}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectRecentColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Palette Colors (sectioned) -->
                    <TextBlock Text="Palette" Foreground="{DynamicResource TextSecondary}" Margin="0,16,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailablePalettes}"
                              SelectedItem="{Binding SelectedPalette, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,8" VerticalAlignment="Center"
                              ToolTip="Select color palette (SNES Classic + custom JSON from assets/palettes)"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320" Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding PaletteSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,6" Margin="0,0,0,6" Opacity="0.85">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding Colors}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="24" Height="24" Margin="2"
                                                            Background="{Binding Converter={StaticResource PixelColorToBrushConverter}}"
                                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                            Cursor="Hand">
                                                        <Border.ToolTip>
                                                            <ToolTip Style="{StaticResource StyledToolTip}"
                                                                     Content="{Binding Converter={StaticResource ColorSwatchToolTipConverter}}"
                                                                     ContentTemplate="{StaticResource ColorSwatchToolTipTemplate}"/>
                                                        </Border.ToolTip>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectPaletteColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
            
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" ShowsPreview="False">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Width="2" Height="30" Background="{DynamicResource BorderBrush}" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Center - Canvas Area -->
            <Border Grid.Column="2" Background="{DynamicResource BackgroundTertiary}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4"
                    PreviewMouseWheel="CanvasArea_PreviewMouseWheel">
                <Grid x:Name="CanvasArea" ClipToBounds="True">
                    <!-- Checkerboard background for transparency -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#404040">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#505050">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    
                    <!-- Canvas Image + Grid Overlay -->
                    <Grid Width="{Binding Canvas.Width, FallbackValue=32}" 
                          Height="{Binding Canvas.Height, FallbackValue=32}"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.LayoutTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                                <TranslateTransform X="{Binding PanOffsetX, Converter={StaticResource NegateConverter}}"
                                                    Y="{Binding PanOffsetY, Converter={StaticResource NegateConverter}}"/>
                            </TransformGroup>
                        </Grid.LayoutTransform>
                        <Image x:Name="CanvasImage" 
                               Source="{Binding CanvasBitmap}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="None"
                               MouseDown="CanvasImage_MouseDown"
                               MouseMove="CanvasImage_MouseMove"
                               MouseUp="CanvasImage_MouseUp">
                        </Image>
                        <!-- Grid overlay: lines at pixel boundaries; thickness 1/Zoom so they stay ~1px on screen -->
                        <ItemsControl ItemsSource="{Binding GridOverlayLines}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                                          Stroke="#404040"
                                          StrokeThickness="{Binding DataContext.Zoom, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseZoomConverter}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>
            
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" ShowsPreview="False">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Width="2" Height="30" Background="{DynamicResource BorderBrush}" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Right Panel - Layers -->
            <Grid Grid.Column="4" x:Name="RightPanel" Background="{DynamicResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Layers" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="+" Style="{DynamicResource ToolButton}" Command="{Binding AddLayerCommand}"
                                    Width="24" Height="24" Margin="0,0,2,0" ToolTip="Add layer"/>
                            <Button Content="−" Style="{DynamicResource ToolButton}" Command="{Binding RemoveLayerCommand}"
                                    Width="24" Height="24" Margin="0,0,2,0" ToolTip="Delete layer"/>
                            <Button Content="⤴" Style="{DynamicResource ToolButton}" Command="{Binding MoveLayerUpCommand}"
                                    Width="24" Height="24" Margin="0,0,2,0" ToolTip="Move layer up"/>
                            <Button Content="⤵" Style="{DynamicResource ToolButton}" Command="{Binding MoveLayerDownCommand}"
                                    Width="24" Height="24" Margin="0,0,2,0" ToolTip="Move layer down"/>
                            <Button Content="⊕" Style="{DynamicResource ToolButton}" Command="{Binding DuplicateLayerCommand}"
                                    Width="24" Height="24" ToolTip="Duplicate layer"/>
                        </StackPanel>
                    </Grid>
                    
                    <ListBox ItemsSource="{Binding Canvas.Layers}" 
                             SelectedIndex="{Binding Canvas.ActiveLayerIndex}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Padding="{TemplateBinding Padding}" 
                                                    SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBg}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SelectionBorder}"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="true"/>
                                                        <Condition Property="Selector.IsSelectionActive" Value="false"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundTertiary}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                </MultiTrigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsVisible}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <Grid Grid.Row="2" Background="{DynamicResource BackgroundSecondary}" Height="24">
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondary}" 
                       Margin="8,0" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
