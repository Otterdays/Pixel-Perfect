<Window x:Class="PixelPerfect.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PixelPerfect.ViewModels"
        mc:Ignorable="d"
        Title="Pixel Perfect" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundPrimary}">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Toolbar -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundSecondary}" Height="40">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <Button Content="New" Style="{StaticResource ToolButton}" Command="{Binding NewCanvasCommand}" Margin="0,0,4,0"/>
                <Button Content="Open" Style="{StaticResource ToolButton}" Margin="0,0,4,0"/>
                <Button Content="Save" Style="{StaticResource ToolButton}" Margin="0,0,16,0"/>
                
                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="0,4,16,4"/>
                
                <TextBlock Text="Zoom:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ZoomLevels}" 
                          SelectedItem="{Binding Zoom}" 
                          Width="60" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Tools & Color -->
            <Grid Grid.Column="0" Background="{StaticResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <!-- Tools Section -->
                    <TextBlock Text="Tools" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    
                    <UniformGrid Columns="4" Margin="0,0,0,16">
                        <Button Content="✏️" Style="{StaticResource ToolButton}" Command="{Binding SelectBrushCommand}" 
                                ToolTip="Brush (B)" Width="36" Height="36" Margin="2"/>
                        <Button Content="🧹" Style="{StaticResource ToolButton}" Command="{Binding SelectEraserCommand}" 
                                ToolTip="Eraser (E)" Width="36" Height="36" Margin="2"/>
                        <Button Content="🪣" Style="{StaticResource ToolButton}" Command="{Binding SelectFillCommand}" 
                                ToolTip="Fill (F)" Width="36" Height="36" Margin="2"/>
                        <Button Content="💧" Style="{StaticResource ToolButton}" Command="{Binding SelectEyedropperCommand}" 
                                ToolTip="Eyedropper (I)" Width="36" Height="36" Margin="2"/>
                    </UniformGrid>
                    
                    <!-- Color Section -->
                    <TextBlock Text="Color" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    
                    <Border Width="64" Height="64" BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="4" HorizontalAlignment="Left">
                        <Border.Background>
                            <SolidColorBrush>
                                <SolidColorBrush.Color>
                                    <MultiBinding Converter="{x:Null}">
                                        <!-- Would need a converter for proper RGBA display -->
                                    </MultiBinding>
                                </SolidColorBrush.Color>
                            </SolidColorBrush>
                        </Border.Background>
                    </Border>
                    
                    <!-- Quick Colors -->
                    <TextBlock Text="Quick Colors" Foreground="{StaticResource TextSecondary}" Margin="0,16,0,8"/>
                    <UniformGrid Columns="8" Margin="0,0,0,8">
                        <!-- Would populate with color swatches -->
                    </UniformGrid>
                </StackPanel>
            </Grid>
            
            <!-- Center - Canvas Area -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundTertiary}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="4">
                <Grid x:Name="CanvasArea" ClipToBounds="True">
                    <!-- Checkerboard background for transparency -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#404040">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#505050">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    
                    <!-- Canvas Image -->
                    <Image x:Name="CanvasImage" 
                           Source="{Binding CanvasBitmap}"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="None"
                           MouseDown="CanvasImage_MouseDown"
                           MouseMove="CanvasImage_MouseMove"
                           MouseUp="CanvasImage_MouseUp">
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                        </Image.LayoutTransform>
                    </Image>
                </Grid>
            </Border>
            
            <!-- Right Panel - Layers -->
            <Grid Grid.Column="2" Background="{StaticResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <Grid>
                        <TextBlock Text="Layers" Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/>
                        <Button Content="+" Style="{StaticResource ToolButton}" Command="{Binding AddLayerCommand}"
                                HorizontalAlignment="Right" Width="24" Height="24"/>
                    </Grid>
                    
                    <ListBox ItemsSource="{Binding Canvas.Layers}" 
                             SelectedIndex="{Binding Canvas.ActiveLayerIndex}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsVisible}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <Grid Grid.Row="2" Background="{StaticResource BackgroundSecondary}" Height="24">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" 
                       Margin="8,0" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
