<Window x:Class="PixelPerfect.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PixelPerfect.ViewModels"
        xmlns:converters="clr-namespace:PixelPerfect.Converters"
        mc:Ignorable="d"
        Title="Pixel Perfect" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimary}">
    
    <Window.Resources>
        <converters:PixelColorToBrushConverter x:Key="PixelColorToBrushConverter"/>
        <converters:NegateConverter x:Key="NegateConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="B" Command="{Binding SelectBrushCommand}"/>
        <KeyBinding Key="E" Command="{Binding SelectEraserCommand}"/>
        <KeyBinding Key="F" Command="{Binding SelectFillCommand}"/>
        <KeyBinding Key="I" Command="{Binding SelectEyedropperCommand}"/>
        <KeyBinding Key="L" Command="{Binding SelectLineCommand}"/>
        <KeyBinding Key="R" Command="{Binding SelectRectangleCommand}"/>
        <KeyBinding Key="C" Command="{Binding SelectCircleCommand}"/>
        <KeyBinding Key="G" Command="{Binding ToggleGridCommand}"/>
        <KeyBinding Key="P" Command="{Binding SelectPanCommand}"/>
        <KeyBinding Key="S" Command="{Binding SelectSelectionCommand}"/>
        <KeyBinding Key="M" Command="{Binding SelectMoveCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewCanvasCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="C" Command="{Binding CopyCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="X" Command="{Binding CutCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="V" Command="{Binding PasteCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="Back" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Toolbar -->
        <Grid Grid.Row="0" Background="{DynamicResource BackgroundSecondary}" Height="40">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <Button Content="New" Style="{DynamicResource ToolButton}" Command="{Binding NewCanvasCommand}" Margin="0,0,4,0"/>
                <Button Content="Open" Style="{DynamicResource ToolButton}" Margin="0,0,4,0"/>
                <Button Content="Save" Style="{DynamicResource ToolButton}" Margin="0,0,16,0" Command="{Binding SaveCommand}" ToolTip="Save to PNG (Ctrl+S)"/>
                
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="0,4,16,4"/>

                <Button Content="Grid" Style="{DynamicResource ToolButton}" Command="{Binding ToggleGridCommand}"
                        ToolTip="Toggle grid overlay (G)" Margin="0,0,16,0"/>
                
                <TextBlock Text="Zoom:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ZoomLevels}" 
                          SelectedItem="{Binding Zoom}" 
                          Width="60" VerticalAlignment="Center"/>
                
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="0,4,16,4"/>
                <TextBlock Text="Theme:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ThemeNames}" 
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" 
                          Width="100" VerticalAlignment="Center" ToolTip="Switch UI theme"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Tools & Color -->
            <Grid Grid.Column="0" Background="{DynamicResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <!-- Tools Section -->
                    <TextBlock Text="Tools" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Size:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="32" Value="{Binding BrushSize}" VerticalAlignment="Center" ToolTip="Brush/Eraser size (px)"/>
                    </Grid>
                    <UniformGrid Columns="4" Margin="0,0,0,16">
                        <Button Content="✏️" Style="{DynamicResource ToolButton}" Command="{Binding SelectBrushCommand}" 
                                ToolTip="Brush (B)" Width="36" Height="36" Margin="2"/>
                        <Button Content="🧹" Style="{DynamicResource ToolButton}" Command="{Binding SelectEraserCommand}" 
                                ToolTip="Eraser (E)" Width="36" Height="36" Margin="2"/>
                        <Button Content="🪣" Style="{DynamicResource ToolButton}" Command="{Binding SelectFillCommand}" 
                                ToolTip="Fill (F)" Width="36" Height="36" Margin="2"/>
                        <Button Content="💧" Style="{DynamicResource ToolButton}" Command="{Binding SelectEyedropperCommand}" 
                                ToolTip="Eyedropper (I)" Width="36" Height="36" Margin="2"/>
                        <Button Content="📏" Style="{DynamicResource ToolButton}" Command="{Binding SelectLineCommand}" 
                                ToolTip="Line (L)" Width="36" Height="36" Margin="2"/>
                        <Button Content="⬛" Style="{DynamicResource ToolButton}" Command="{Binding SelectRectangleCommand}" 
                                ToolTip="Rectangle (R)" Width="36" Height="36" Margin="2"/>
                        <Button Content="⚪" Style="{DynamicResource ToolButton}" Command="{Binding SelectCircleCommand}" 
                                ToolTip="Circle (C)" Width="36" Height="36" Margin="2"/>
                        <Button Content="✋" Style="{DynamicResource ToolButton}" Command="{Binding SelectPanCommand}" 
                                ToolTip="Pan (P)" Width="36" Height="36" Margin="2"/>
                        <Button Content="⬚" Style="{DynamicResource ToolButton}" Command="{Binding SelectSelectionCommand}" 
                                ToolTip="Selection (S)" Width="36" Height="36" Margin="2"/>
                        <Button Content="✥" Style="{DynamicResource ToolButton}" Command="{Binding SelectMoveCommand}" 
                                ToolTip="Move (M)" Width="36" Height="36" Margin="2"/>
                    </UniformGrid>
                    
                    <!-- Color Section -->
                    <TextBlock Text="Color" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                    
                    <Border Width="64" Height="64" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="4" HorizontalAlignment="Left" Background="{Binding CurrentColor, Converter={StaticResource PixelColorToBrushConverter}}">
                    </Border>
                    
                    <!-- Palette Colors -->
                    <TextBlock Text="Palette" Foreground="{DynamicResource TextSecondary}" Margin="0,16,0,8"/>
                    <ItemsControl ItemsSource="{Binding PaletteColors}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="24" Height="24" Margin="2"
                                        Background="{Binding Converter={StaticResource PixelColorToBrushConverter}}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectPaletteColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
            
            <!-- Center - Canvas Area -->
            <Border Grid.Column="1" Background="{DynamicResource BackgroundTertiary}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4">
                <Grid x:Name="CanvasArea" ClipToBounds="True">
                    <!-- Checkerboard background for transparency -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#404040">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#505050">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    
                    <!-- Canvas Image + Grid Overlay -->
                    <Grid Width="{Binding Canvas.Width, FallbackValue=32}" 
                          Height="{Binding Canvas.Height, FallbackValue=32}"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.LayoutTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                                <TranslateTransform X="{Binding PanOffsetX, Converter={StaticResource NegateConverter}}"
                                                    Y="{Binding PanOffsetY, Converter={StaticResource NegateConverter}}"/>
                            </TransformGroup>
                        </Grid.LayoutTransform>
                        <Image x:Name="CanvasImage" 
                               Source="{Binding CanvasBitmap}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="None"
                               MouseDown="CanvasImage_MouseDown"
                               MouseMove="CanvasImage_MouseMove"
                               MouseUp="CanvasImage_MouseUp">
                        </Image>
                        <!-- Grid overlay: black lines at pixel boundaries -->
                        <ItemsControl ItemsSource="{Binding GridOverlayLines}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                                          Stroke="#404040" StrokeThickness="1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Right Panel - Layers -->
            <Grid Grid.Column="2" Background="{DynamicResource BackgroundSecondary}" Margin="4">
                <StackPanel Margin="8">
                    <Grid>
                        <TextBlock Text="Layers" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                        <Button Content="+" Style="{DynamicResource ToolButton}" Command="{Binding AddLayerCommand}"
                                HorizontalAlignment="Right" Width="24" Height="24"/>
                    </Grid>
                    
                    <ListBox ItemsSource="{Binding Canvas.Layers}" 
                             SelectedIndex="{Binding Canvas.ActiveLayerIndex}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Padding="{TemplateBinding Padding}" 
                                                    SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBg}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SelectionBorder}"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="true"/>
                                                        <Condition Property="Selector.IsSelectionActive" Value="false"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundTertiary}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                </MultiTrigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsVisible}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <Grid Grid.Row="2" Background="{DynamicResource BackgroundSecondary}" Height="24">
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondary}" 
                       Margin="8,0" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
