<Window x:Class="PixelPerfect.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="360" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Canvas" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Grid color" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Border Width="32" Height="24" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Background="{Binding GridColorBrush}"/>
                <Button Content="Dark" Style="{DynamicResource ToolButton}" Padding="8,4" Margin="0,0,4,0" Click="PresetDark_Click"/>
                <Button Content="Light" Style="{DynamicResource ToolButton}" Padding="8,4" Margin="0,0,4,0" Click="PresetLight_Click"/>
                <Button Content="Contrast" Style="{DynamicResource ToolButton}" Padding="8,4" Click="PresetHighContrast_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Checkerboard" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Color 1" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,0,2"/>
                    <Border Height="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="{Binding CheckerboardColor1Brush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Color 2" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,0,2"/>
                    <Border Height="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="{Binding CheckerboardColor2Brush}"/>
                </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Dark" Style="{DynamicResource ToolButton}" Padding="6,2" Margin="0,0,4,0" Click="PresetDark_Click"/>
                <Button Content="Light" Style="{DynamicResource ToolButton}" Padding="6,2" Margin="0,0,4,0" Click="PresetLight_Click"/>
                <Button Content="Contrast" Style="{DynamicResource ToolButton}" Padding="6,2" Click="PresetHighContrast_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Undo history limit" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
            <ComboBox x:Name="UndoLimitCombo" Width="120" HorizontalAlignment="Left"
                      ItemsSource="{Binding UndoHistoryLimitOptions}"
                      SelectedItem="{Binding UndoHistoryLimit, Mode=TwoWay}"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Style="{DynamicResource ToolButton}" Width="80" Height="28"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Style="{DynamicResource ToolButton}" Width="80" Height="28"
                    Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
