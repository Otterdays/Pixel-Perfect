<Window x:Class="PixelPerfect.Views.NewCanvasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Canvas"
        Width="320" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Canvas Size" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
        
        <ComboBox x:Name="PresetCombo" Grid.Row="1" 
                  SelectedIndex="2"
                  SelectionChanged="PresetCombo_SelectionChanged"
                  Margin="0,0,0,8"/>
        
        <Grid x:Name="CustomSizePanel" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Width:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="WidthBox" Grid.Column="1" Width="60" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <TextBlock Grid.Column="2" Text="Height:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="HeightBox" Grid.Column="3" Width="60" VerticalAlignment="Center"/>
        </Grid>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Style="{DynamicResource ToolButton}" Width="80" Height="28" 
                    Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Style="{DynamicResource ToolButton}" Width="80" Height="28" 
                    Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
